# Pravaah Framework — Environment Variables
# Copy to .env and customize

# Application
PRAVAAH_APP__DEBUG=true
PRAVAAH_APP__HOST=0.0.0.0
PRAVAAH_APP__PORT=8000

# Database
PRAVAAH_DATABASE__URL=sqlite+aiosqlite:///./pravaah.db
PRAVAAH_DATABASE__ECHO=false

# AI (set your API key here)
PRAVAAH_AI__ENABLED=false
PRAVAAH_AI__PROVIDER=openai
PRAVAAH_AI__API_KEY=sk-your-key-here
PRAVAAH_AI__MODEL=gpt-4o-mini
